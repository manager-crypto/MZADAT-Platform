# ─────────────────────────────────────────────────────────────────────────────
# MZADAT Super Admin - Environment Variables
# Copy this file to `.env` and fill in your own values.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Go backend API
VITE_API_URL=http://localhost:8080

# Token storage key (do not change unless you know what you're doing)
VITE_TOKEN_KEY=mzadat_admin_token

# Session timeout in minutes (must match backend session duration)
VITE_SESSION_TIMEOUT_MIN=1440
