# ─────────────────────────────────────────────────────────────────────────────
# MZADAT Platform - Environment Variables
# Copy this file to `.env` and fill in your own values.
# DO NOT commit `.env` to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# All VITE_ prefixed vars are injected into the browser bundle at build time.
VITE_API_URL=http://localhost:8080
VITE_ENABLE_MOCK_FALLBACK=true

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=mzadat
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=mzadat_db
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend (Go) ────────────────────────────────────────────────────────────
BACKEND_PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Admin Seed (used by ./cmd/seed) ─────────────────────────────────────────
# IMPORTANT: change these to strong values BEFORE running in any non-local env!
ADMIN_SEED_EMAIL=admin@mzadat.com
ADMIN_SEED_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ── SMS Gateway (for customer OTP) ──────────────────────────────────────────
# Provider: console | unifonic | twilio
# - console: OTPs printed to Backend logs (dev only — no SMS sent)
# - unifonic: primary provider for KSA. Sign up at https://www.unifonic.com
# - twilio: international fallback. Sign up at https://www.twilio.com
SMS_PROVIDER=console

# Unifonic (KSA) — used when SMS_PROVIDER=unifonic
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=MZADAT

# Twilio — used when SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Bid Engine ──────────────────────────────────────────────────────────────
# When TRUST_PROXY=1, the backend honors X-Forwarded-For from upstream proxies.
# Set to 1 when running behind nginx / Cloudflare. Default 0 (direct connection).
TRUST_PROXY=0

# ── Nafath (National Single Sign-On) ────────────────────────────────────────
# Per Infath spec: bidders must authenticate via Nafath.
# Obtain credentials at https://nafath.sa/business
# Leave NAFATH_ENABLED=false until contracts are in place — falls back to OTP-only.
NAFATH_ENABLED=false
NAFATH_API_URL=https://api.nafath.sa/api/v1
NAFATH_CLIENT_ID=
NAFATH_CLIENT_SECRET=
NAFATH_CALLBACK_URL=https://api.mzadat.com/api/auth/nafath/callback

# ── SADAD Payment Gateway ───────────────────────────────────────────────────
# Per Infath spec: deposits must integrate with SADAD.
# Obtain credentials from your sponsoring bank (Al Rajhi, SNB, etc.).
# Leave SADAD_ENABLED=false until contracts are in place — uses placeholder bills.
SADAD_ENABLED=false
SADAD_BILLER_CODE=
SADAD_API_URL=
SADAD_API_USERNAME=
SADAD_API_PASSWORD=

# ── REGA / FAL (Real Estate General Authority) ──────────────────────────────
# Per REGA spec: real estate auctions require FAL license verification.
# Mooj API: https://rega.gov.sa/en/services/Mooj
REGA_ENABLED=false
REGA_API_URL=https://api.rega.gov.sa/v1
REGA_API_KEY=

# ── Frontend WebSocket URL ─────────────────────────────────────────────────
# When unset, the frontend derives WS URL from the page origin (recommended).
# Override only if WS lives on a different host than the API.
# VITE_GO_AUCTION_WS_URL=wss://ws.mzadat.com/ws/auction
